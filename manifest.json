{
  "manifest_version": 3,
  "name": "ChatGPT Question Sidebar",
  "version": "0.1.0",
  "description": "在 ChatGPT 右侧显示当前对话中用户提过的问题导航。",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}